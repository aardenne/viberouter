# VibeRouter Environment Variables
# Copy to .env and fill in your values.
# These can also be set with VIBEROUTER_ prefix in config.yaml or env.

# Logging
VIBEROUTER_LOG_LEVEL=INFO

# Ports
VIBEROUTER_METRICS_PORT=9090
VIBEROUTER_DASHBOARD_PORT=8080

# Routing
VIBEROUTER_STRATEGY=type_preferred
VIBEROUTER_FALLBACK_ENABLED=true
VIBEROUTER_FALLBACK_THRESHOLD=3

# Optional: Node API keys (not required for local vLLM endpoints)
# VIBEROUTER_XIAOMI_KEY=your-api-key-here
